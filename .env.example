# --- API base (chọn một cách) ---
#
# Khuyến nghị local: trỏ thẳng Spring Boot — tránh lệ thuộc proxy Vite (POST /api/v1/... vẫn 404 trên :5173).
# Phải trùng port với server.port / SERVER_PORT của backend (mặc định 8080).
# VITE_BACKEND_* vẫn dùng cho proxy /uploads /ws và khi bạn dùng lại relative URL.
VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1
VITE_API_URL=http://127.0.0.1:8080/api/v1
# Trong code, path gọi API chỉ là /deposits, /vehicles... (không lặp /api/v1). Nếu lặp → URL .../api/v1/api/v1/... → 404.
#
# Cách 2 — qua proxy Vite (cùng origin :5173): bắt buộc có "/" đầu. Không dùng "api/v1" (thiếu /).
# VITE_API_BASE_URL=/api/v1
# VITE_API_URL=/api/v1
#
# Timeout HTTP (ms). Bỏ trống: dev 60000, production 30000. Tăng nếu tạo thanh toán/ZaloPay qua backend chậm.
# VITE_API_TIMEOUT_MS=90000
# Host/port backend Spring Boot (proxy Vite + URL trên). Đổi nếu backend không chạy 8080.
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8080
# Luôn dùng API thật (mặc định). Chỉ đặt mock nếu cần debug build tách biệt — UI không còn nhánh dữ liệu giả.
VITE_DATA_SOURCE=api

# --- Google OAuth ---
# Google Client ID cho đăng nhập bằng Google. Tạo tại https://console.cloud.google.com/apis/credentials
# Chọn loại "Web application", thêm Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- GoongMap ---
# Đăng ký tại account.goong.io để lấy key
# Maptiles key: dùng để hiển thị bản đồ chi nhánh
VITE_GOONG_MAPTILES_KEY=your-goong-maptiles-key
# API key: dùng cho geocoding, directions (dự phòng)
VITE_GOONG_API_KEY=your-goong-api-key

# --- AI Chatbot (RAG) ---
# Host/port backend FastAPI RAG chatbot (proxy Vite). Đổi nếu chatbot không chạy port 8000.
VITE_AI_CHATBOT_HOST=127.0.0.1
VITE_AI_CHATBOT_PORT=8000