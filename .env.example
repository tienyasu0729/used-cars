# axiosInstance (services mới): prefix API — dev nên để /api/v1 để đi qua proxy Vite
VITE_API_BASE_URL=/api/v1
# Legacy apiClient.ts
VITE_API_URL=/api
# Host/port backend Spring Boot (proxy Vite). Mặc 127.0.0.1:8080 — đổi nếu SERVER_PORT khác.
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8080
# mock = dữ liệu giả cho nhiều màn hình; đặt lịch lái thử vẫn luôn gọi API chỗ trống + POST
VITE_DATA_SOURCE=api

# Tùy chọn — upload ảnh xe (manager) lên Cloudinary (unsigned upload preset).
# Thiếu hoặc để trống: vẫn đăng xe bình thường, không gửi ảnh (bổ sung sau qua sửa tin).
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
