# axiosInstance (services mới): prefix API — dev nên để /api/v1 để đi qua proxy Vite
VITE_API_BASE_URL=/api/v1
# Legacy apiClient.ts — cùng prefix với backend (/api/v1)
VITE_API_URL=/api/v1
# Host/port backend Spring Boot (proxy Vite). Mặc 127.0.0.1:8080 — đổi nếu SERVER_PORT khác.
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8080
# Luôn dùng API thật (mặc định). Chỉ đặt mock nếu cần debug build tách biệt — UI không còn nhánh dữ liệu giả.
VITE_DATA_SOURCE=api

# Upload ảnh Cloudinary: cấu hình trên backend (used-cars-backend), không đặt VITE_* ở đây.
# Xem application.yml → app.cloudinary hoặc biến môi trường: CLOUDINARY_CLOUD_NAME, CLOUDINARY_UPLOAD_PRESET.
