# Runtime configuration for Vite.
# Vite loads this file automatically. .env.example is documentation only.

# --- API ---
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_API_URL=http://localhost:8080/api/v1
VITE_API_TIMEOUT_MS=90000

# --- Spring Boot backend ---
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8080
VITE_DATA_SOURCE=api

# --- Google OAuth ---
# Google Console must include the exact frontend origin:
# http://localhost:5173 and/or http://127.0.0.1:5173.
VITE_GOOGLE_AUTH_ORIGIN=http://localhost:5173
VITE_GOOGLE_CLIENT_ID=295380430968-io62k6mffrmk3avcuf1l0r4c9o46fvpe.apps.googleusercontent.com

# --- GoongMap ---
VITE_GOONG_MAPTILES_KEY=inccV0BGthPts6p1YyGJDJbLvrF196zY2b6gckrt
VITE_GOONG_API_KEY=wzyXcuejq1UBzXsMRLN5mEj8ajclJol22ZNTPb6u

# --- AI Chatbot (RAG) ---
# Enable only when the FastAPI RAG chatbot is running.
VITE_AI_CHATBOT_ENABLED=true
VITE_AI_CHATBOT_HOST=127.0.0.1
VITE_AI_CHATBOT_PORT=8000

# --- Cloudinary public upload ---
VITE_CLOUDINARY_CLOUD_NAME=degmf4c2i
VITE_CLOUDINARY_UPLOAD_PRESET=ml_default
