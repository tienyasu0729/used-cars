name: Deploy Frontend



on:

  push:

    branches:

      - main



jobs:

  deploy:

    runs-on: ubuntu-latest



    steps:

      - name: Deploy frontend

        uses: appleboy/ssh-action@master



        with:

          host: ${{ secrets.HOST }}

          username: ${{ secrets.USERNAME }}

          key: ${{ secrets.SSH_KEY }}

          port: ${{ secrets.PORT }}



          script: |

            cd /var/www/used-cars



            git reset --hard



            git pull origin main



            npm install



            npm run build



            pm2 reload used-cars || pm2 start npm --name used-cars -- start
